# AI-CORE Service Host Environment Configuration Example
ENVIRONMENT=development

# DB Configuration - pointing to local docker container mapped to port 5433
AI_CORE_DATABASE_URL=postgresql+asyncpg://postgres:postgres_master_password@localhost:5433/postgres

# Redis Configuration - pointing to local docker container mapped to port 6379
REDIS_URL=redis://localhost:6379/1

# Provider keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
TAVILY_API_KEY=

# Gateway security header signature key
GATEWAY_SIGNING_SECRET=default-gateway-signing-secret-key-change-me-in-production
