# AI-CORE Service Host Environment Configuration
ENVIRONMENT=development

# DB Configuration
AI_CORE_DATABASE_URL=postgresql+asyncpg://postgres:postgres_password@localhost:5432/postgres

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Provider keys
TAVILY_API_KEY=

# Gateway security header signature key
GATEWAY_SIGNING_SECRET=your_gateway_signing_secret_here

# Redis Stack Configuration (Vector Search)
REDIS_STACK_URL=redis://localhost:6399/0
SEMANTIC_CACHE_THRESHOLD=0.92
SEMANTIC_CACHE_TTL=86400

# Kafka Configuration
KAFKA_BROKERS=localhost:9092
