# ==============================================================================
# Solavie Platform Environment Configuration Example
# Copy this file to .env and adjust the credentials.
# ==============================================================================

# --- PostgreSQL Superuser ---
POSTGRES_PASSWORD=postgres_master_password

# --- Keycloak Database Credentials ---
# Must match the password defined in scripts/init-databases.sql or be overridden
KC_DB_PASSWORD=keycloak_password

# --- Keycloak Administrator Credentials ---
KC_ADMIN=admin
KC_ADMIN_PASSWORD=admin_secret_pass

# --- Infrastructure Host & Ports ---
DOMAIN=localhost
KEYCLOAK_PORT=8081
KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443
KONG_ADMIN_PORT=8001

# --- Default Tenant ---
DEFAULT_TENANT_ID=tenant-test-uuid

# --- Gateway & Rate Limiting ---
KONG_ISSUER_URL=http://localhost:8081/realms/solavie
RATE_LIMIT_MINUTE=200
RATE_LIMIT_HOUR=5000
GATEWAY_SIGNING_SECRET=default-gateway-signing-secret-key-change-me-in-production
KONG_MASTER_REALM_TENANT_ID=solavie-system-master

# --- Service Discovery & Fallback URLs ---
TENANT_CONFIG_INTERNAL_URL=http://tenant-config:3006
MOCK_API_INTERNAL_URL=http://127.0.0.1:80
GATEWAY_FALLBACK_TARGET=127.0.0.1:8000
REGISTRY_SYNC_POLL_INTERVAL=5
DEFAULT_TENANT_ID=tenant-test-uuid
DEFAULT_RATE_LIMIT_MINUTE=200
DEFAULT_RATE_LIMIT_HOUR=5000
REDIS_INTERNAL_HOST=redis-master-1
REDIS_INTERNAL_PORT=6379
KEYCLOAK_INTERNAL_URL=http://keycloak:8080
CHANNEL_CONNECTOR_INTERNAL_URL=http://channel-connector:3001
USER_SERVICE_DB_PASSWORD=solavie_user_password
KONG_DB_PASSWORD=kong_password
